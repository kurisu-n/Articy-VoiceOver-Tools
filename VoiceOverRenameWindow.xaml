<Window x:Class="Kurisu.VoiceOverNamingScheme.VoiceOverRenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kurisu.VoiceOverNamingScheme"
        mc:Ignorable="d"
        Title="Voice-Over Rename Planner"
        Height="720" Width="960"
        WindowStartupLocation="CenterOwner"
        Style="{DynamicResource ArticyWindowStyle}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Kurisu.VoiceOverNamingScheme;component/Resources/ArticyTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="ScopeTextBlock"
                   Grid.Row="0"
                   Style="{DynamicResource HeaderTextStyle}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

        <Border Grid.Row="1"
                Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource BorderLightBrush}"
                BorderThickness="1"
                Padding="6"
                Margin="0,0,0,8">
            <Grid x:Name="SummaryGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ToggleButton Grid.Row="0" Grid.Column="0"
                              x:Name="AlreadyCorrectToggle"
                              Style="{DynamicResource CategoryToggleStyle}"
                              IsChecked="False" Tag="0"
                              Click="CategoryFilter_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x2713;" Foreground="{DynamicResource OkBrush}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Margin="0,0,6,0"/>
                        <StackPanel>
                            <TextBlock x:Name="AlreadyCorrectCount" Text="0" FontWeight="Bold"/>
                            <TextBlock Text="Already correct" Style="{DynamicResource HintTextStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton Grid.Row="0" Grid.Column="1"
                              x:Name="WillRenameToggle"
                              Style="{DynamicResource CategoryToggleStyle}"
                              IsChecked="True" Tag="1"
                              Click="CategoryFilter_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x00BB;" Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Margin="0,0,6,0"/>
                        <StackPanel>
                            <TextBlock x:Name="WillRenameCount" Text="0" FontWeight="Bold"/>
                            <TextBlock Text="Will rename" Style="{DynamicResource HintTextStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton Grid.Row="0" Grid.Column="2"
                              x:Name="DisplayOnlyToggle"
                              Style="{DynamicResource CategoryToggleStyle}"
                              IsChecked="True" Tag="2"
                              Click="CategoryFilter_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x25CB;" Foreground="{DynamicResource WarnBrush}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Margin="0,0,6,0"/>
                        <StackPanel>
                            <TextBlock x:Name="DisplayOnlyCount" Text="0" FontWeight="Bold"/>
                            <TextBlock Text="Display only" Style="{DynamicResource HintTextStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton Grid.Row="0" Grid.Column="3"
                              x:Name="TargetExistsToggle"
                              Style="{DynamicResource CategoryToggleStyle}"
                              IsChecked="True" Tag="3"
                              Click="CategoryFilter_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x26A0;" Foreground="{DynamicResource WarnBrush}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Margin="0,0,6,0"/>
                        <StackPanel>
                            <TextBlock x:Name="TargetExistsCount" Text="0" FontWeight="Bold"/>
                            <TextBlock Text="Target exists, skip" Style="{DynamicResource HintTextStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton Grid.Row="0" Grid.Column="4"
                              x:Name="SourceMissingToggle"
                              Style="{DynamicResource CategoryToggleStyle}"
                              IsChecked="True" Tag="4"
                              Click="CategoryFilter_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x2717;" Foreground="{DynamicResource DangerBrush}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Margin="0,0,6,0"/>
                        <StackPanel>
                            <TextBlock x:Name="SourceMissingCount" Text="0" FontWeight="Bold"/>
                            <TextBlock Text="Source missing" Style="{DynamicResource HintTextStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </ToggleButton>

                <TextBlock Grid.Row="1" Grid.ColumnSpan="5"
                           x:Name="FilterStatusTextBlock"
                           Style="{DynamicResource HintTextStyle}"
                           Text="Click a category to toggle it on/off."
                           Margin="2,4,0,0"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Style="{DynamicResource HintTextStyle}"
                       Text="Select a row, then jump to it in Articy:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
            <Button x:Name="ShowFragmentButton"
                    Content="Show Fragment"
                    Width="140" Height="26"
                    Margin="0,0,6,0"
                    IsEnabled="False"
                    Click="ShowFragmentButton_Click"/>
            <Button x:Name="ShowAssetButton"
                    Content="Show VO Asset"
                    Width="140" Height="26"
                    IsEnabled="False"
                    Click="ShowAssetButton_Click"/>
            <TextBlock Style="{DynamicResource HintTextStyle}"
                       Text="(window stays open — navigate multiple entries, then Cancel or Run when done)"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"/>
        </StackPanel>

        <Border Grid.Row="3"
                BorderBrush="{DynamicResource BorderDarkBrush}"
                BorderThickness="1"
                Background="{DynamicResource DarkBgBrush}">
            <ListBox x:Name="PlanListBox"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     SelectionChanged="PlanListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,2,0,4">
                            <!-- Header row -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="{Binding Icon}"
                                           Foreground="{Binding IconBrush}"
                                           FontFamily="Consolas"
                                           FontWeight="Bold"
                                           FontSize="13"
                                           Width="22"/>
                                <TextBlock Text="{Binding Header}"
                                           FontFamily="Segoe UI"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- File sub-row -->
                            <Grid Margin="26,0,0,1"
                                  Visibility="{Binding HasFileLine, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="file"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="11"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding FileLine}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </Grid>

                            <!-- Display sub-row -->
                            <Grid Margin="26,0,0,0"
                                  Visibility="{Binding HasDisplayLine, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="display"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="11"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayLine}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <GroupBox Grid.Row="4" Header="Action" Margin="0,10,0,8" Padding="8">
            <StackPanel>
                <RadioButton x:Name="DryRunRadio" IsChecked="True">
                    <TextBlock TextWrapping="Wrap">
                        <Run FontWeight="Bold">Dry run</Run> &#8212; preview only, no files copied or assets changed.
                    </TextBlock>
                </RadioButton>
                <RadioButton x:Name="ExecuteRadio">
                    <TextBlock TextWrapping="Wrap">
                        <Run FontWeight="Bold" Foreground="{DynamicResource AccentBrush}">Execute rename</Run> &#8212; apply the plan above. &quot;Already correct&quot; / &quot;Target exists&quot; / &quot;Source missing&quot; entries are skipped automatically.
                    </TextBlock>
                </RadioButton>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="100" Height="30" Margin="0,0,8,0"
                    Click="CancelButton_Click"
                    IsCancel="True"/>
            <Button x:Name="RunButton"
                    Content="Run"
                    Width="100" Height="30"
                    Click="RunButton_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
