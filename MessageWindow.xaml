<Window x:Class="Kurisu.VoiceOverTools.MessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kurisu.VoiceOverTools"
        mc:Ignorable="d"
        Title="Message"
        Height="360" Width="520"
        WindowStartupLocation="CenterOwner"
        Style="{DynamicResource ArticyWindowStyle}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Kurisu.VoiceOverTools;component/Resources/ArticyTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource DarkBgBrush}"
                BorderBrush="{DynamicResource BorderDarkBrush}"
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                <TextBlock x:Name="MessageTextBlock"
                           TextWrapping="Wrap"
                           Padding="12"
                           FontSize="13"
                           FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="1"
                Content="OK"
                Width="100" Height="30"
                Margin="0,10,0,0"
                HorizontalAlignment="Right"
                IsDefault="True"
                IsCancel="True"
                Click="OkButton_Click"/>
    </Grid>
</Window>
