<Window x:Class="Kurisu.VoiceOverTools.VoiceOverAuditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kurisu.VoiceOverTools"
        mc:Ignorable="d"
        Title="Voice-Over Audit"
        Height="640" Width="900"
        WindowStartupLocation="CenterOwner"
        Style="{DynamicResource ArticyWindowStyle}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Kurisu.VoiceOverTools;component/Resources/ArticyTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="ScopeTextBlock"
                   Grid.Row="0"
                   Style="{DynamicResource HeaderTextStyle}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

        <Border Grid.Row="1"
                Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource BorderLightBrush}"
                BorderThickness="1"
                Padding="6"
                Margin="0,0,0,8">
            <Grid x:Name="SummaryGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ToggleButton Grid.Row="0" Grid.Column="0"
                              x:Name="MissingToggle"
                              Style="{DynamicResource CategoryToggleStyle}"
                              IsChecked="True" Tag="0"
                              Click="CategoryFilter_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⌀" Foreground="{DynamicResource WarnBrush}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Margin="0,0,6,0"/>
                        <StackPanel>
                            <TextBlock x:Name="MissingCount" Text="0" FontWeight="Bold"/>
                            <TextBlock Text="Missing VO" Style="{DynamicResource HintTextStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton Grid.Row="0" Grid.Column="1"
                              x:Name="CorruptedToggle"
                              Style="{DynamicResource CategoryToggleStyle}"
                              IsChecked="True" Tag="1"
                              Click="CategoryFilter_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✗" Foreground="{DynamicResource DangerBrush}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Margin="0,0,6,0"/>
                        <StackPanel>
                            <TextBlock x:Name="CorruptedCount" Text="0" FontWeight="Bold"/>
                            <TextBlock Text="Corrupted VO" Style="{DynamicResource HintTextStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton Grid.Row="0" Grid.Column="2"
                              x:Name="OverlappingToggle"
                              Style="{DynamicResource CategoryToggleStyle}"
                              IsChecked="True" Tag="2"
                              Click="CategoryFilter_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⇄" Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Margin="0,0,6,0"/>
                        <StackPanel>
                            <TextBlock x:Name="OverlappingCount" Text="0" FontWeight="Bold"/>
                            <TextBlock Text="Overlapping VO" Style="{DynamicResource HintTextStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </ToggleButton>

                <TextBlock Grid.Row="1" Grid.ColumnSpan="3"
                           x:Name="FilterStatusTextBlock"
                           Style="{DynamicResource HintTextStyle}"
                           Text="Click a category to toggle it on/off."
                           Margin="2,4,0,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Character:"
                           VerticalAlignment="Center"
                           Style="{DynamicResource HintTextStyle}"
                           Margin="0,0,6,0"/>
                <ComboBox x:Name="CharacterFilterComboBox"
                          MinWidth="180"
                          Height="26"
                          VerticalContentAlignment="Center"
                          SelectionChanged="CharacterFilterComboBox_SelectionChanged"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Style="{DynamicResource HintTextStyle}"
                           Text="Select a row to jump:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <Button x:Name="ShowFragmentButton"
                        Content="Show Fragment"
                        Width="140" Height="26"
                        Margin="0,0,6,0"
                        IsEnabled="False"
                        Click="ShowFragmentButton_Click"/>
                <Button x:Name="ShowAssetButton"
                        Content="Show VO Asset"
                        Width="140" Height="26"
                        IsEnabled="False"
                        Click="ShowAssetButton_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="3"
                BorderBrush="{DynamicResource BorderDarkBrush}"
                BorderThickness="1"
                Background="{DynamicResource DarkBgBrush}">
            <ListBox x:Name="AuditListBox"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     SelectionChanged="AuditListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2,4,2,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- HEADER: [icon + Category badge] · Speaker · ID + Lang -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding Icon}"
                                           Foreground="{Binding IconBrush}"
                                           FontFamily="Segoe UI Symbol"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding CategoryLabel}"
                                           Foreground="{Binding IconBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,16,0"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding SpeakerName}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="3"
                                           Text="{Binding IdAndLang}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- PATH -->
                            <TextBlock Grid.Row="1"
                                       Text="{Binding FragmentPath}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="26,4,0,0"/>

                            <!-- LINE (the actual dialogue) -->
                            <Border Grid.Row="2"
                                    Background="{DynamicResource PanelBgBrush}"
                                    BorderBrush="{DynamicResource BorderDarkBrush}"
                                    BorderThickness="0,0,0,0"
                                    Margin="26,4,0,0"
                                    Padding="8,4">
                                <TextBlock Text="{Binding LineText}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="12"
                                           FontStyle="Italic"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <!-- DETAIL -->
                            <Grid Grid.Row="3" Margin="26,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="ⓘ"
                                           Foreground="{Binding IconBrush}"
                                           FontFamily="Segoe UI Symbol"
                                           FontSize="11"
                                           VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Detail}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="4,0,0,0"/>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="CloseButton"
                    Content="Close"
                    Width="100" Height="30"
                    Click="CloseButton_Click"
                    IsCancel="True"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
